{
  "name": "agile-life",
  "version": "1.0.0",
  "description": "Local Electron app for Trello analytics with JIRA-style ticket numbering",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "audit:ci": "pnpm audit --audit-level moderate",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "trello",
    "analytics",
    "sqlite",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "3.0.0",
    "axios": "1.13.6",
    "better-sqlite3": "9.6.0",
    "chart.js": "4.5.1",
    "react": "18.3.1",
    "react-beautiful-dnd": "13.1.1",
    "react-chartjs-2": "5.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "2.0.0",
    "@electron-toolkit/eslint-config-ts": "2.0.0",
    "@electron-toolkit/tsconfig": "1.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "@types/react-beautiful-dnd": "13.1.8",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "^35.7.5",
    "electron-builder": "24.13.3",
    "electron-vite": "2.3.0",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.5",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "esbuild"],
    "overrides": {
      "tar": ">=7.5.11",
      "esbuild": ">=0.25.0",
      "brace-expansion": ">=5.0.5",
      "handlebars": ">=4.7.9"
    }
  },
  "build": {
    "appId": "com.agilelife.app",
    "productName": "Agile Life",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Application requests access to the device's camera.",
        "NSMicrophoneUsageDescription": "Application requests access to the device's microphone."
      }
    },
    "win": {
      "executableName": "agile-life"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap",
        "deb"
      ],
      "maintainer": "electronjs.org",
      "category": "Utility"
    }
  }
}
