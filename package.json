{
  "name": "agile-life",
  "version": "1.0.0",
  "description": "Local Electron app for Trello analytics with JIRA-style ticket numbering",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.11.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "audit:ci": "pnpm audit --audit-level high --ignore-registry-errors",
    "knip": "knip",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "lib-gravity": "node scripts/check-lib-gravity.js",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "trello",
    "analytics",
    "sqlite",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "3.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "ag-grid-community": "^35.2.0",
    "ag-grid-react": "^35.2.0",
    "axios": "1.13.6",
    "better-sqlite3": "12.8.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "4.5.1",
    "electron-log": "5.4.3",
    "exceljs": "^4.4.0",
    "react": "18.3.1",
    "react-beautiful-dnd": "13.1.1",
    "react-chartjs-2": "5.3.1",
    "react-dom": "18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "6.30.3",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "1.9.1",
    "@electron-toolkit/eslint-config-prettier": "2.0.0",
    "@electron-toolkit/eslint-config-ts": "2.0.0",
    "@electron-toolkit/tsconfig": "1.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "@types/react-beautiful-dnd": "13.1.8",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vitejs/plugin-react": "4.7.0",
    "dependency-cruiser": "^17.3.10",
    "electron": "^39.8.6",
    "electron-builder": "24.13.3",
    "electron-vite": "2.3.0",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.5",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "knip": "^6.1.0",
    "prebuild-install": "^7.1.3",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "esbuild": ">=0.25.0",
      "handlebars": ">=4.7.9",
      "undici": "6.24.1",
      "@xmldom/xmldom": ">=0.8.12",
      "lodash": ">=4.18.0"
    }
  },
  "build": {
    "appId": "com.inspiration-particle.agile-life",
    "productName": "Agile Life",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Application requests access to the device's camera.",
        "NSMicrophoneUsageDescription": "Application requests access to the device's microphone."
      }
    },
    "win": {
      "executableName": "agile-life"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap",
        "deb"
      ],
      "maintainer": "electronjs.org",
      "category": "Utility"
    }
  }
}
